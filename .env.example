# Database
DATABASE_URL=postgresql://socialisn2:CHANGEME@postgres:5432/socialisn2
POSTGRES_PASSWORD=CHANGEME              # consumed by docker-compose postgres service
REDIS_URL=redis://redis:6379

# LLM
# Inside docker-compose the LiteLLM proxy is reachable at http://litellm:4000/.
# For local dev runs outside compose, use http://localhost:4000/. Override to a
# remote LiteLLM endpoint by setting both values.
LITELLM_BASE_URL=http://litellm:4000/
LITELLM_API_KEY=                        # master key matches config/litellm.yaml + docker-compose env
OPENAI_API_KEY=                         # for embeddings (direct OpenAI, not via LiteLLM)
GOOGLE_AI_API_KEY=                      # for LiteLLM's Gemini route (normalise stage, SPEC §7.3)
ANTHROPIC_API_KEY=                      # for LiteLLM's Claude route (curate stage, Phase 3 PR 3)

# 2nd-brain MCP — consumed by src/lib/two_brain_client.ts (Phase 3 PR 1).
# Optional: if either is empty, archive_search degrades to [] and record_pick
# degrades to {ok:false} per SPEC §10.2, and the scoring run continues with
# archive_overlap=0. Set both to enable Stage 5 archive-overlap scoring.
#
# ALSO consumed by scripts/post-deploy-backfill.ts (Phase 5 PR 2) — when set,
# the post-deploy assertion expects brain_corpus_status === 'available'; if
# either is unset the deploy exits non-zero rather than silently shipping a
# misconfigured prod with brain_corpus_status='not_configured'. Leaving the
# URL blank here (rather than a placeholder) produces the clearer
# 'not_configured' abort when an operator forgets to fill it in.
TWO_BRAIN_MCP_URL=
TWO_BRAIN_MCP_TOKEN=

# --- The block below is forward-looking config. The current code doesn't
# --- read these yet; they're listed so deployers know what's coming and
# --- can populate secrets early. As each phase lands, the relevant block
# --- moves above this comment.

# This server's MCP (Phase 4 PR 3)
SOCIALISN2_MCP_TOKEN=                   # bearer for inbound MCP

# Telegram (Phase 4 PR 2)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=                       # Simon's chat ID

# YouTube Data API (Phase 5 PR 1 — backfill of Simon's own channel only;
# competitor channel polling uses the public Atom feed and does NOT need
# this key).
YOUTUBE_API_KEY=

# GDELT (no auth, but rate limit key) — consumed today by src/ingestion/gdelt.ts
GDELT_USER_AGENT=socialisn2/1.0 (simon@...)

# Email-bridge (§6.9) — Cloudflare Email Worker output served as RSS
# Consumed today by src/ingestion/email_bridge.ts
EMAIL_BRIDGE_BASE=https://inbox.socialisn.com

# Cost (SPEC §12) — consumed today by src/cost/ledger.ts + src/config/env.ts.
#
# Ceiling sized at the 95th one-sided percentile of the expected daily
# spend distribution, NOT at the median. A ceiling at the median trips
# ~50% of the time, which makes it a normal-operations gate that
# starves the scoring-worker tick (returns ceiling_hit, raw_items
# queue grows). A ceiling is a safety net against anomalies (runaway
# prompt size, retry storm, mis-routed model billing at fallback
# rates), so it should fire on ≤5% of days, not on Tuesdays.
#
# Math (2026-05-30): expected band $1.20-$1.90/day at current
# Gemini-routed steady state -> μ≈$1.55, σ≈$0.35. Threshold at
# μ+1.645σ ≈ $2.13 for 95% one-sided coverage. Rounded up to $2.20
# to account for right-skew (large prompt tails) without going so
# high that real anomalies escape detection. Revisit with measured σ
# after 14 days of clean ledger data at this operating profile;
# Phase 3 will split into per-stage sub-budgets, each sized at its
# own μ+1.645σ.
COST_CEILING_DAILY_USD=2.20
COST_ALERT_THRESHOLD=0.80

# Schedule (Phase 3 PR 4 — twice-daily scoring run orchestrator)
SCHEDULE_MORNING_CRON=0 5 * * *         # 05:00 ET
SCHEDULE_AFTERNOON_CRON=0 14 * * *      # 14:00 ET
TZ=America/New_York

# Ingestion worker
INGESTION_SCHEDULER_TICK_CRON=* * * * * # how often the scheduler checks for due sources
INGESTION_CONCURRENCY=8                 # max concurrent fetches inside the BullMQ worker
HTTP_USER_AGENT=socialisn2/0.1 (+https://github.com/unsubject/socialisn2)
HTTP_TIMEOUT_MS=30000

# Scoring worker (continuous Phase 2 pipeline + daily compaction).
# All four optional — defaults match src/config/env.ts and are sane for
# the v1 single-process VPS deploy.
SCORING_WORKER_TICK_CRON=* * * * *      # how often the worker pulls pending raw_items
SCORING_WORKER_COMPACTION_CRON=0 4 * * * # daily compactClusters pass (04:00 UTC)
SCORING_WORKER_BATCH_SIZE=20            # max raw_items processed per tick
SCORING_WORKER_MAX_ATTEMPTS=3           # poison-row retry cap

# Public-facing (Phase 4 PR 1 — src/rss/generate.ts + Fastify entrypoint;
# Phase 5 PR 2 — VPS deploy).
#
# PUBLIC_HOST is rendered into every RSS feed's <link> elements and the
# /c/:id detail-page URLs that subscribers click. Must match the
# externally-reachable hostname after Traefik + Cloudflare termination.
# RSS_PATH is where the orchestrator writes the 6 *.xml files; matched
# by docker-compose's feeds_data volume + the nginx `alias` directive in
# infra/nginx/socialisn2.conf.
PUBLIC_HOST=mcp.socialisn.com
RSS_PATH=/var/www/socialisn2/feeds

# Source-authority recalibration (Obs-3 / ADR-013). Daily Bayesian update
# of sources.authority_score from the last 30 days of feedback. Default
# 04:00 UTC slots between morning + afternoon scoring runs so it doesn't
# compete for DB. RECALIBRATE_PRIOR_STRENGTH (k) controls how heavily the
# seed authority anchors the posterior — k=20 means ~20 picks/passes
# before a source's calibrated score moves materially away from its seed.
#
# Reduced from 20 to 5 on 2026-05-30. Rationale: with one user making
# ~1 pick/pass/defer per day spread across 138 seeded sources, a given
# source sees a feedback row roughly every 30-60 days. k=20 implicitly
# trusts the seed as much as 20 user decisions, which means correcting
# a wrong seed (e.g. authority=90 for a source whose picks suggest 60)
# takes 2-5 YEARS of usage to converge. k=5 cuts that to a few months
# while still anchoring noisily-seeded sources against early-life
# pick/pass thrash. If the calibrated scores ever oscillate
# materially, raise back toward 10.
RECALIBRATE_CRON=0 4 * * *
RECALIBRATE_PRIOR_STRENGTH=5

# Orchestrator (Phase 5 PR 4 + Build task U0xDaFVlYkpZVW02aEcwdg) —
# the twice-daily Stages 3-7 scoring run cron. Supersedes the older
# SCHEDULE_MORNING_CRON / SCHEDULE_AFTERNOON_CRON / TZ placeholders
# above (left in place pending a separate cleanup). Defaults match
# SPEC §9; the timezone is pinned at cron-registration time so the
# schedule is independent of host TZ.
ORCHESTRATOR_MORNING_CRON=0 5 * * *
ORCHESTRATOR_AFTERNOON_CRON=0 14 * * *
ORCHESTRATOR_TIMEZONE=America/New_York
