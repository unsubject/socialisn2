# Database
DATABASE_URL=postgresql://socialisn2:CHANGEME@postgres:5432/socialisn2
POSTGRES_PASSWORD=CHANGEME              # consumed by docker-compose postgres service
REDIS_URL=redis://redis:6379

# LLM
# Inside docker-compose the LiteLLM proxy is reachable at http://litellm:4000/.
# For local dev runs outside compose, use http://localhost:4000/. Override to a
# remote LiteLLM endpoint by setting both values.
LITELLM_BASE_URL=http://litellm:4000/
LITELLM_API_KEY=                        # master key matches config/litellm.yaml + docker-compose env
OPENAI_API_KEY=                         # for embeddings (direct OpenAI, not via LiteLLM)
GOOGLE_AI_API_KEY=                      # for LiteLLM's Gemini route (normalise stage, SPEC §7.3)
ANTHROPIC_API_KEY=                      # for LiteLLM's Claude route (curate stage, Phase 3 PR 3)

# 2nd-brain MCP — consumed by src/lib/two_brain_client.ts (Phase 3 PR 1).
# Optional: if either is empty, archive_search degrades to [] and record_pick
# degrades to {ok:false} per SPEC §10.2, and the scoring run continues with
# archive_overlap=0. Set both to enable Stage 5 archive-overlap scoring.
TWO_BRAIN_MCP_URL=https://2ndbrain.<simon-host>/mcp
TWO_BRAIN_MCP_TOKEN=

# --- The block below is forward-looking config. The current code doesn't
# --- read these yet; they're listed so deployers know what's coming and
# --- can populate secrets early. As each phase lands, the relevant block
# --- moves above this comment.

# This server's MCP (Phase 4 PR 3)
SOCIALISN2_MCP_TOKEN=                   # bearer for inbound MCP

# Telegram (Phase 4 PR 2)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=                       # Simon's chat ID

# YouTube Data API (Phase 5 PR 1 — backfill of Simon's own channel only;
# competitor channel polling uses the public Atom feed and does NOT need
# this key).
YOUTUBE_API_KEY=

# GDELT (no auth, but rate limit key) — consumed today by src/ingestion/gdelt.ts
GDELT_USER_AGENT=socialisn2/1.0 (simon@...)

# Email-bridge (§6.9) — Cloudflare Email Worker output served as RSS
# Consumed today by src/ingestion/email_bridge.ts
EMAIL_BRIDGE_BASE=https://inbox.socialisn.com

# Cost (SPEC §12) — consumed today by src/cost/ledger.ts + src/config/env.ts
COST_CEILING_DAILY_USD=1.50
COST_ALERT_THRESHOLD=0.80

# Schedule (Phase 3 PR 4 — twice-daily scoring run orchestrator)
SCHEDULE_MORNING_CRON=0 5 * * *         # 05:00 ET
SCHEDULE_AFTERNOON_CRON=0 14 * * *      # 14:00 ET
TZ=America/New_York

# Ingestion worker
INGESTION_SCHEDULER_TICK_CRON=* * * * * # how often the scheduler checks for due sources
INGESTION_CONCURRENCY=8                 # max concurrent fetches inside the BullMQ worker
HTTP_USER_AGENT=socialisn2/0.1 (+https://github.com/unsubject/socialisn2)
HTTP_TIMEOUT_MS=30000

# Scoring worker (continuous Phase 2 pipeline + daily compaction).
# All four optional — defaults match src/config/env.ts and are sane for
# the v1 single-process VPS deploy.
SCORING_WORKER_TICK_CRON=* * * * *      # how often the worker pulls pending raw_items
SCORING_WORKER_COMPACTION_CRON=0 4 * * * # daily compactClusters pass (04:00 UTC)
SCORING_WORKER_BATCH_SIZE=20            # max raw_items processed per tick
SCORING_WORKER_MAX_ATTEMPTS=3           # poison-row retry cap

# Public-facing (Phase 4 PR 1 — src/rss/generate.ts + Fastify entrypoint)
PUBLIC_HOST=socialisn2.<simon-host>
RSS_PATH=/var/www/socialisn2/feeds
