{
  "name": "socialisn2-email-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Cloudflare Email Worker — inbound newsletter handler for SPEC §6.9. Parses mail, maps to a source slug via D1 sender_map, writes to inbox or unmatched.",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "d1:apply:remote": "bash ../scripts/apply-d1-migrations.sh"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240924.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.7",
    "wrangler": "^4.94.0"
  },
  "dependencies": {
    "postal-mime": "^2.2.7"
  }
}
